# ── Supabase API (Dashboard > Settings > API) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# service_role key — hanya untuk script setup/seed. Gunakan key yang SUDAH di-rotate.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Koneksi DB untuk script setup (Settings > Database > Connection string > URI) ──
# Ganti [YOUR-PASSWORD] dengan database password project kamu.
SUPABASE_DB_URL=postgresql://postgres.YOUR-REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── Akun admin yang dibuat otomatis oleh scripts/setup.mjs ──────────
ADMIN_EMAIL=admin@mti.or.id
ADMIN_PASSWORD=ganti-password-kuat
